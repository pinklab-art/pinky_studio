{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "기본 권한 + BLE(blec) 권한 + Jupyter 링크(opener)",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "blec:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "http://*" }, { "url": "https://*" }]
    }
  ]
}
