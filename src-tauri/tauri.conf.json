{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pinky Studio",
  "mainBinaryName": "pinky-studio",
  "version": "0.1.0",
  "identifier": "art.pinklab.pinky.desktop",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Pinky Studio",
        "label": "main",
        "width": 508,
        "height": 869,
        "minWidth": 480,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
